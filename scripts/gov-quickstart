#!/bin/bash
# WF 2026-02-28
# Quick start script for GOV dataset
# see https://github.com/WolfgangFahl/pyomnigraph/issues/32

set -e
NAME="GOV"
DATASET="gov_full"
DOWNLOAD_URL="https://genwiki-farm.genealogy.net/downloads/$DATASET.tar.gz"
DOWNLOAD_DIR="${HOME}/.omnigraph/rdf_dumps/$DATASET"
TAR_FILE="${DOWNLOAD_DIR}/$DATASET.tar.gz"

echo "=== $NAME Dataset Quick Start ==="

mkdir -p "${DOWNLOAD_DIR}"

if [ ! -f "${TAR_FILE}" ]; then
    echo "Downloading $NAME dataset..."
    curl -L -o "${TAR_FILE}" "${DOWNLOAD_URL}"
    echo "✅ Download complete"
else
    echo "✅ Using cached: ${TAR_FILE}"
fi

echo "Extracting..."
cd "${DOWNLOAD_DIR}"
tar -xzf $TAR_FILE
echo "✅ Extracted"

echo "Starting Blazegraph..."
omnigraph -s blazegraph --cmd start

echo "Loading $NAME dataset..."
omnigraph -s blazegraph --cmd load --datasets $DATASET

echo "✅ Done! Opening web UI..."
omnigraph -s blazegraph --cmd webui
